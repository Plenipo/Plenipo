# Copy to .env and edit. The .env file is your deployment's identity — never commit it.

# REQUIRED — the only mandatory setting. Generate one: openssl rand -hex 24
POSTGRES_PASSWORD=

# Image + port
#CORTEX_IMAGE=ghcr.io/your-org/cortex-sample:0.1.0   # pin a tag; default builds from source
#CORTEX_PORT=8080

# Environment: Development = keyless demo (Mock AI, X-Dev-* header auth).
# Production requires configuring a real identity provider first.
#CORTEX_ENVIRONMENT=Development

# AI provider (default Mock — no key needed). For a real model, one of:
#AI_PROVIDER=OpenAI          # or AzureOpenAI / Anthropic / Ollama
#AI_MODEL=gpt-4o-mini        # Anthropic example: claude-sonnet-4-5
#AI_API_KEY=sk-...
#EMBEDDING_PROVIDER=OpenAI

# Tenants can also switch provider/model/key at RUNTIME from the admin console (AI Settings) —
# the key is stored write-only in the secret vault, not in this file.

# Optional deploy-time extras (configured via Ai__/Mcp__ env vars or an appsettings overlay):
#   MCP tool servers:  Mcp__Servers__0__Name=github  Mcp__Servers__0__Transport=Stdio
#                      Mcp__Servers__0__Command=npx  Mcp__Servers__0__Arguments__0=-y ...
#   Secret storage:    Secrets__Provider=AzureKeyVault + Secrets__KeyVaultUri=... (default: DataProtection)
# See docs/CONFIGURATION.md for the full reference.
